<%- include('header') %>

    <div class="container">

        <div class="form-container">

            <h1 class="heading">Edit Book</h1>

            <form action="/update-book/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

                <div class="form-group">
                    <input type="text" name="title" value="<%= book.title %>">
                </div>

                <div class="form-group">
                    <input type="text" name="author" value="<%= book.author %>">
                </div>

                <div class="form-group">
                    <input type="text" name="category" value="<%= book.category %>">
                </div>

                <div class="form-group">
                    <input type="number" name="price" value="<%= book.price %>">
                </div>

                <div class="form-group">
                    <input type="number" name="quantity" value="<%= book.quantity %>">
                </div>

                <div class="form-group">
                    <textarea name="description"><%= book.description %></textarea>
                </div>

                <div class="form-group">
                    <input type="file" name="image">
                </div>

                <button class="btn btn-primary">
                    Update Book
                </button>

            </form>

        </div>

    </div>

    <%- include('footer') %>